#!/usr/bin/env bash
# xtest — drive a remote Linux VM as the build/test target for The Bowery.
#
# Designed for a VirtualBox VM running stock Ubuntu 22.04+ / 24.04 (which
# has BPF-LSM, BTF, and a current Rust-buildable toolchain), but works
# against any SSH-reachable Linux host.
#
# Workflow:
#   1. Spin up the VM, enable SSH, set XTEST_HOST in .xtest.env.
#   2. ./scripts/xtest setup        # one-time: install Rust + build deps
#   3. ./scripts/xtest doctor       # confirm the kernel is ready
#   4. ./scripts/xtest test         # iterate
#
# Subcommands (run `xtest help` for full list):
#   setup       Install Rust toolchain + build deps + bpffs on the target.
#   sync        rsync the workspace to the target (excludes target/, .git/objects).
#   build       sync + cargo build [--release].
#   test        sync + cargo test --workspace [extra cargo args].
#   clippy      sync + cargo clippy --workspace --all-targets -- -D warnings.
#   fmt-check   sync + cargo fmt --all -- --check.
#   ci          Full CI mirror: fmt-check, clippy, test, release build.
#   doctor      Build the CLI on the target, then run `bowery doctor`.
#   probe       Print kernel, distro, and BPF readiness summary.
#   shell       Open an interactive SSH session inside the synced workdir.
#   exec [-t] ARG..
#               Run an arbitrary command on the target inside the workdir.
#               Pass -t / --tty to allocate a pseudo-tty (needed for sudo).
#   push-model [NAME]
#               rsync a model from $HOME/.bowery/models/<NAME>.gguf locally
#               to the same path on the target. Default NAME is
#               `qwen3-0.6b-q4_k_m`. No-op when the remote already has the
#               same file (rsync size + mtime check). Local copy must
#               already exist; run `bowery model fetch <NAME>` to get one.
#   run-agent [--push-model [NAME]] [--config PATH] [--no-bpf] [--no-llm] \
#             [--log FILTER] [-- ARGS...]
#               sync + (optional) push-model + build the BPF object + build
#               the agent (release, with llm-llama-cpp by default) + run
#               it with sudo. Streams agent stdout/stderr to your terminal
#               until you ctrl-c.
#   run-console [--no-llm] [--push-model [NAME]] [-- ARGS...]
#               sync + build bowery-console (release, with llm-llama-cpp by
#               default) + run. Forward console flags after `--`. Console
#               will offer to download Gemma 4 on first run unless --push-model
#               or a previous fetch already placed it.
#   stop-ssh    Tear down the SSH ControlMaster connection.
#
# Config is read from $REPO/.xtest.env, environment variables override:
#   XTEST_HOST          (required) hostname/IP of the VM (e.g. 127.0.0.1 for NAT, 192.168.x.x for bridged)
#   XTEST_USER          (default: $USER)
#   XTEST_PORT          (default: 22; use the NAT-forwarded port for VirtualBox)
#   XTEST_SSH_KEY       (default: ~/.ssh/id_ed25519)
#   XTEST_REMOTE_PATH   (default: /home/$XTEST_USER/the_bowery)
#   XTEST_CARGO_FLAGS   (extra flags for build/test, e.g. "--release")

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

# --- Config ------------------------------------------------------------------

ENV_FILE="$REPO_ROOT/.xtest.env"
if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck source=/dev/null
    source "$ENV_FILE"
    set +a
fi

: "${XTEST_USER:=$USER}"
: "${XTEST_PORT:=22}"
: "${XTEST_SSH_KEY:=$HOME/.ssh/id_ed25519}"
: "${XTEST_REMOTE_PATH:=/home/${XTEST_USER}/the_bowery}"
: "${XTEST_CARGO_FLAGS:=}"

# Subcommands that talk to the VM call this. `help` skips it so it
# works even without a config file. Sets SOCK_NAME, SSH_CTL, and
# ssh_opts as a side effect.
require_config() {
    if [[ -z "${XTEST_HOST:-}" ]]; then
        echo "error: XTEST_HOST not set" >&2
        echo "       create $ENV_FILE (see scripts/.xtest.env.example) or export XTEST_HOST" >&2
        exit 2
    fi
    SOCK_NAME="$(printf '%s' "$XTEST_HOST" | tr '/.: ' '____')"
    SSH_CTL="$REPO_ROOT/.xtest-ssh-${SOCK_NAME}.sock"
    ssh_opts=(
        -i "$XTEST_SSH_KEY"
        -p "$XTEST_PORT"
        -o ControlMaster=auto
        -o "ControlPath=$SSH_CTL"
        -o ControlPersist=10m
        -o StrictHostKeyChecking=accept-new
        -o ServerAliveInterval=30
        -o LogLevel=ERROR
    )
}

# --- SSH plumbing ------------------------------------------------------------

# Build the rsh string rsync passes to ssh. Requires `require_config` first.
rsync_rsh() {
    printf "ssh -i '%s' -p '%s' -o ControlPath='%s' -o ControlMaster=auto -o ControlPersist=10m -o StrictHostKeyChecking=accept-new -o LogLevel=ERROR" \
        "$XTEST_SSH_KEY" "$XTEST_PORT" "$SSH_CTL"
}

ssh_cmd() {
    ssh "${ssh_opts[@]}" "$XTEST_USER@$XTEST_HOST" "$@"
}

# Run a command in a fresh (non-multiplexed) interactive SSH session
# with a dedicated pty. Used by `setup` for sudo: per-tty timestamp
# caches mean separate `ssh_cmd` calls each get their own "tty" and
# would re-prompt — keeping the whole setup in one session lets a
# single password unlock everything.
ssh_cmd_tty() {
    ssh -tt -o ControlMaster=no \
        -i "$XTEST_SSH_KEY" \
        -p "$XTEST_PORT" \
        -o StrictHostKeyChecking=accept-new \
        -o LogLevel=ERROR \
        "$XTEST_USER@$XTEST_HOST" "$@"
}

# Run a command inside REMOTE_PATH after sourcing cargo's env. Stdin is
# inherited so the caller can pipe input through.
remote() {
    local cmd="$1"
    ssh_cmd "set -e
        if [ -f \"\$HOME/.cargo/env\" ]; then . \"\$HOME/.cargo/env\"; fi
        cd \"$XTEST_REMOTE_PATH\"
        $cmd"
}

# --- Subcommands -------------------------------------------------------------

cmd_help() {
    # Print the file's leading banner — every line of `# …` comments
    # before the first blank-or-code line. Lets us add subcommand help
    # without remembering to bump a hardcoded line range.
    awk 'BEGIN { in_banner=1 }
         in_banner && /^#/ { sub(/^# ?/, ""); print; next }
         in_banner && /^$/ { exit }
         { exit }' "${BASH_SOURCE[0]}"
}

cmd_sync() {
    require_config
    echo "==> sync $REPO_ROOT/ -> $XTEST_USER@$XTEST_HOST:$XTEST_REMOTE_PATH/"
    # `/target/` and `crates/*/target/` are anchored separately because
    # bowery-ebpf is its own workspace with its own target/ — those build
    # artifacts only exist on the VM (cross-compiled with bpf-linker) and
    # rsync --delete would otherwise wipe them every sync.
    rsync -az --delete \
        --exclude='/target/' \
        --exclude='/crates/*/target/' \
        --exclude='/.git/objects/' \
        --exclude='/.git/lfs/' \
        --exclude='*.swp' \
        --exclude='*.swo' \
        --exclude='.idea/' \
        --exclude='.vscode/' \
        --exclude='*:Zone.Identifier' \
        --exclude='/.xtest-ssh-*.sock' \
        --exclude='/.xtest.env' \
        -e "$(rsync_rsh)" \
        "$REPO_ROOT/" \
        "$XTEST_USER@$XTEST_HOST:$XTEST_REMOTE_PATH/"
}

cmd_setup() {
    require_config

    # Build the entire setup as one shell script. Substitution:
    # __REMOTE_PATH__ → $XTEST_REMOTE_PATH (only thing the local side
    # needs to inject). All `$HOME` / `$USER` / `$(uname -r)` stay
    # literal and resolve on the remote.
    local script
    script=$(cat <<'REMOTE'
set -e

echo "==> probing the target"
uname -a
cat /etc/os-release 2>/dev/null | grep -E "^(NAME|VERSION_ID)=" || true

echo
echo "==> forcing apt to use IPv4 (works around VirtualBox NAT/bridge IPv6 stalls)"
echo 'Acquire::ForceIPv4 "true";' | sudo tee /etc/apt/apt.conf.d/99force-ipv4 >/dev/null

echo
echo "==> installing system build deps (sudo will prompt once if needed)"
sudo apt-get update -qq
DEBIAN_FRONTEND=noninteractive sudo apt-get install -y \
    build-essential pkg-config curl git ca-certificates \
    clang llvm cmake \
    "linux-headers-$(uname -r)" \
    libbpf-dev \
    bpftrace

echo
echo "==> installing bpftool (best-effort; package name varies)"
if ! DEBIAN_FRONTEND=noninteractive sudo apt-get install -y bpftool 2>/dev/null; then
    if ! DEBIAN_FRONTEND=noninteractive sudo apt-get install -y \
            linux-tools-common "linux-tools-$(uname -r)" 2>/dev/null; then
        if ! DEBIAN_FRONTEND=noninteractive sudo apt-get install -y \
                linux-tools-generic 2>/dev/null; then
            echo "(bpftool not installed; not strictly required for builds)"
        fi
    fi
fi

echo
echo "==> installing rustup (idempotent)"
if [ ! -x "$HOME/.cargo/bin/cargo" ]; then
    curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain stable --profile minimal
else
    . "$HOME/.cargo/env" && rustup self update >/dev/null 2>&1 || true
fi

echo
echo "==> installing BPF build toolchain (nightly + rust-src + bpf-linker)"
. "$HOME/.cargo/env"
rustup toolchain install nightly --profile minimal --component rust-src
# bpf-linker is the LLVM-backed linker that produces BPF bytecode.
# It builds against the system LLVM. Skip if already present.
if ! command -v bpf-linker >/dev/null; then
    cargo install bpf-linker
fi

echo
echo "==> mounting bpffs (idempotent)"
if ! mount | grep -q "^bpf "; then
    sudo mount -t bpf bpf /sys/fs/bpf
fi
if ! grep -q "^bpf " /etc/fstab; then
    echo "bpf  /sys/fs/bpf  bpf  defaults  0  0" | sudo tee -a /etc/fstab > /dev/null
fi

echo
echo "==> creating remote workdir __REMOTE_PATH__"
mkdir -p "__REMOTE_PATH__"

echo
echo "Setup complete."
REMOTE
)
    # Inject the remote workdir path. __REMOTE_PATH__ is a unique
    # sentinel so we don't have to worry about collisions with shell
    # syntax inside the heredoc.
    script="${script//__REMOTE_PATH__/$XTEST_REMOTE_PATH}"

    # Single ssh -tt session; sudo prompts once and the per-tty
    # timestamp covers the rest of the script.
    ssh_cmd_tty "$script"

    echo
    echo "Try: $0 doctor"
}

cmd_build() {
    cmd_sync
    echo "==> cargo build $XTEST_CARGO_FLAGS $*"
    remote "cargo build --workspace $XTEST_CARGO_FLAGS $*"
    # Also exercise the console's llama.cpp feature path. The
    # workspace build above compiles bowery-console without
    # features (mock chat backend); this second pass catches
    # breakage in the LLM-on path before it shows up in
    # `run-console`.
    echo "==> cargo build --release -p bowery-console --features llm-llama-cpp"
    remote "RUSTFLAGS='-C target-cpu=native' cargo build --release -p bowery-console --features llm-llama-cpp"
}

cmd_test() {
    cmd_sync
    echo "==> cargo test --workspace $XTEST_CARGO_FLAGS $*"
    remote "cargo test --workspace $XTEST_CARGO_FLAGS $*"
}

cmd_clippy() {
    cmd_sync
    echo "==> cargo clippy --workspace --all-targets -- -D warnings"
    remote "cargo clippy --workspace --all-targets -- -D warnings"
}

cmd_fmt_check() {
    cmd_sync
    echo "==> cargo fmt --all -- --check"
    remote "cargo fmt --all -- --check"
}

cmd_ci() {
    cmd_sync
    echo
    echo "==> [1/4] cargo fmt --all -- --check"
    remote "cargo fmt --all -- --check"
    echo
    echo "==> [2/4] cargo clippy --workspace --all-targets -- -D warnings"
    remote "cargo clippy --workspace --all-targets -- -D warnings"
    echo
    echo "==> [3/4] cargo test --workspace"
    remote "cargo test --workspace"
    echo
    echo "==> [4/5] cargo build --workspace --release"
    remote "cargo build --workspace --release"
    echo
    echo "==> [5/5] cargo build --release -p bowery-console --features llm-llama-cpp"
    remote "RUSTFLAGS='-C target-cpu=native' cargo build --release -p bowery-console --features llm-llama-cpp"
    echo
    echo "All CI steps passed."
}

cmd_doctor() {
    cmd_sync
    echo "==> building bowery-cli on the target"
    remote "cargo build --release -p bowery-cli >/dev/null"
    echo
    echo "==> ./target/release/bowery doctor"
    remote "./target/release/bowery doctor"
}

cmd_probe() {
    require_config
    echo "== target ==              $XTEST_USER@$XTEST_HOST:$XTEST_PORT"
    echo "== remote workdir ==      $XTEST_REMOTE_PATH"
    echo
    echo "== kernel =="
    ssh_cmd 'uname -r'
    echo
    echo "== distro =="
    ssh_cmd 'grep -E "^(NAME|VERSION)=" /etc/os-release || true'
    echo
    echo "== /sys/kernel/security/lsm =="
    ssh_cmd 'cat /sys/kernel/security/lsm 2>/dev/null || echo "(unreadable)"'
    echo
    echo "== /sys/kernel/btf/vmlinux =="
    ssh_cmd 'ls -lh /sys/kernel/btf/vmlinux 2>/dev/null || echo "(missing)"'
    echo
    echo "== bpffs =="
    ssh_cmd 'mount | grep -E "^bpf " || echo "(not mounted)"'
}

cmd_shell() {
    require_config
    ssh_cmd "cd '$XTEST_REMOTE_PATH' && exec \$SHELL -l"
}

cmd_exec() {
    require_config
    local tty=0
    if [[ "${1:-}" == "-t" || "${1:-}" == "--tty" ]]; then
        tty=1
        shift
    fi
    if [[ $# -eq 0 ]]; then
        echo "usage: $0 exec [-t] <command> [args...]" >&2
        echo "  -t, --tty    allocate a pseudo-tty (needed for interactive sudo)" >&2
        exit 2
    fi
    if [[ $tty -eq 1 ]]; then
        # ssh_cmd_tty bypasses ControlMaster on purpose: per-tty sudo
        # timestamps mean a fresh tty is the only way to ensure
        # password prompts work reliably.
        ssh_cmd_tty "set -e
            if [ -f \"\$HOME/.cargo/env\" ]; then . \"\$HOME/.cargo/env\"; fi
            cd \"$XTEST_REMOTE_PATH\"
            $*"
    else
        remote "$*"
    fi
}

cmd_push_model() {
    require_config
    local name="${1:-qwen3-0.6b-q4_k_m}"
    local local_path="$HOME/.bowery/models/${name}.gguf"
    if [[ ! -f "$local_path" ]]; then
        echo "error: $local_path not found locally" >&2
        echo "       run: bowery model fetch $name" >&2
        exit 2
    fi
    local remote_dir="/home/$XTEST_USER/.bowery/models"
    local remote_path="$remote_dir/${name}.gguf"
    local size_bytes
    size_bytes=$(stat -c %s "$local_path" 2>/dev/null || stat -f %z "$local_path")
    local size_h
    if (( size_bytes >= 1 << 30 )); then
        size_h="$(awk "BEGIN { printf \"%.1f GiB\", $size_bytes / (1024*1024*1024) }")"
    else
        size_h="$(( size_bytes >> 20 )) MiB"
    fi
    echo "==> push-model $name ($size_h) -> $XTEST_USER@$XTEST_HOST:$remote_path"
    ssh_cmd "mkdir -p '$remote_dir'"
    # `--info=progress2` gives a single overall progress line; default
    # rsync size+mtime check makes this a near-instant no-op on
    # subsequent runs when the file hasn't changed locally.
    rsync -aH --info=progress2 \
        -e "$(rsync_rsh)" \
        "$local_path" \
        "$XTEST_USER@$XTEST_HOST:$remote_path"
}

cmd_run_agent() {
    require_config
    local config="/tmp/bowery-agent.toml"
    local with_bpf=1
    local with_llm=1
    local log="info,bowery_agent=info,bowery_ebpf_loader=info"
    local push_model=0
    local push_model_name="qwen3-0.6b-q4_k_m"
    local agent_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --config)
                config="${2:?--config needs a path}"
                shift 2
                ;;
            --no-bpf)
                with_bpf=0
                shift
                ;;
            --no-llm)
                with_llm=0
                shift
                ;;
            --log)
                log="${2:?--log needs a filter}"
                shift 2
                ;;
            --push-model)
                push_model=1
                # Optional trailing NAME: take it if the next arg
                # doesn't look like another flag.
                if [[ -n "${2:-}" && ! "${2:-}" == --* ]]; then
                    push_model_name="$2"
                    shift 2
                else
                    shift 1
                fi
                ;;
            --)
                shift
                agent_args+=("$@")
                break
                ;;
            *)
                echo "error: unknown run-agent flag '$1'" >&2
                echo "usage: $0 run-agent [--push-model [NAME]] [--config PATH] [--no-bpf] [--no-llm] [--log FILTER] [-- ARGS...]" >&2
                exit 2
                ;;
        esac
    done

    cmd_sync

    if [[ $push_model -eq 1 ]]; then
        echo
        cmd_push_model "$push_model_name"
    fi

    # 1. Build the BPF object (separate workspace, nightly toolchain).
    if [[ $with_bpf -eq 1 ]]; then
        echo
        echo "==> [1/3] building BPF object (nightly + bpf-linker)"
        remote "bash scripts/build-ebpf"
    else
        echo
        echo "==> [1/3] skipping BPF build (--no-bpf)"
    fi

    # 2. Build the agent (release; with llm-llama-cpp unless --no-llm).
    #
    # When llama-cpp is enabled we set RUSTFLAGS="-C target-cpu=native"
    # so llama-cpp-sys-2's build.rs activates GGML_NATIVE=ON and the
    # bundled llama.cpp matches the build CPU's exact feature set. The
    # default Rust target features for x86_64-unknown-linux-gnu are a
    # generic baseline, but llama.cpp's runtime CPU dispatch can still
    # pick an AVX path that the runtime CPU doesn't support, producing
    # SIGILL with no Rust-level error message. Forcing target-cpu=native
    # avoids the mismatch — safe here because build host == run host.
    echo
    if [[ $with_llm -eq 1 ]]; then
        echo "==> [2/3] cargo build --release -p bowery-agent --features llm-llama-cpp"
        remote "RUSTFLAGS='-C target-cpu=native' cargo build --release -p bowery-agent --features llm-llama-cpp"
    else
        echo "==> [2/3] cargo build --release -p bowery-agent"
        remote "cargo build --release -p bowery-agent"
    fi

    # 3. Run the agent under sudo. Needs a TTY for the sudo password
    # prompt; ssh_cmd_tty deliberately bypasses ControlMaster so the
    # per-tty sudo timestamp covers the whole session.
    echo
    echo "==> [3/3] running agent (ctrl-c to stop)"
    local bpf_env=""
    if [[ $with_bpf -eq 1 ]]; then
        # BOWERY_BPF_DEV_MODE is required alongside BOWERY_BPF_OBJ_PATH
        # post Phase-8 H8 (integrity-checked loader). The dev path
        # under target/ is owned by the build user, not root, so the
        # production-mode integrity check would refuse to load it.
        bpf_env="BOWERY_BPF_DEV_MODE=1 BOWERY_BPF_OBJ_PATH=\$PWD/crates/bowery-ebpf/target/bpfel-unknown-none/release/bowery-ebpf"
    fi
    local extra=""
    if [[ ${#agent_args[@]} -gt 0 ]]; then
        # Pass agent_args verbatim. They're already shell-quoted by the
        # caller's invocation; here we just join with spaces.
        extra=" ${agent_args[*]}"
    fi
    ssh_cmd_tty "set -e
        if [ -f \"\$HOME/.cargo/env\" ]; then . \"\$HOME/.cargo/env\"; fi
        cd \"$XTEST_REMOTE_PATH\"
        sudo $bpf_env RUST_LOG='$log' \
            ./target/release/bowery-agent --config '$config'$extra"
}

cmd_run_console() {
    require_config
    local with_llm=1
    local push_model=0
    local push_model_name="gemma-4-e2b-it-q4_k_m"
    local console_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-llm)
                with_llm=0
                shift
                ;;
            --push-model)
                push_model=1
                if [[ -n "${2:-}" && ! "${2:-}" == --* ]]; then
                    push_model_name="$2"
                    shift 2
                else
                    shift 1
                fi
                ;;
            --)
                shift
                console_args+=("$@")
                break
                ;;
            -h|--help)
                cat <<HELP
xtest run-console — sync, build, and run the operator console on the VM.

Usage: $0 run-console [--no-llm] [--push-model [NAME]] [-- ARGS...]

Flags:
  --no-llm          Build without --features llm-llama-cpp (mock chat).
  --push-model [N]  rsync ~/.bowery/models/<N>.gguf to the same path on
                    the target before launch. Default N is
                    'gemma-4-e2b-it-q4_k_m'. Without this the console
                    will offer to download Gemma 4 on first run.
  -- ARGS...        Extra args forwarded verbatim to bowery-console
                    (e.g. --agent-addr, --agent-fp, --agent-pubkey-b64,
                    --operator-key).
HELP
                return 0
                ;;
            *)
                echo "error: unknown run-console flag '$1'" >&2
                exit 2
                ;;
        esac
    done

    cmd_sync

    if [[ $push_model -eq 1 ]]; then
        echo
        cmd_push_model "$push_model_name"
    fi

    echo
    if [[ $with_llm -eq 1 ]]; then
        echo "==> cargo build --release -p bowery-console --features llm-llama-cpp"
        remote "RUSTFLAGS='-C target-cpu=native' cargo build --release -p bowery-console --features llm-llama-cpp"
    else
        echo "==> cargo build --release -p bowery-console (mock chat)"
        remote "cargo build --release -p bowery-console"
    fi

    echo
    echo "==> running bowery-console (ctrl-c to exit; alt screen will tear down cleanly)"
    local extra=""
    if [[ ${#console_args[@]} -gt 0 ]]; then
        extra=" ${console_args[*]}"
    fi
    ssh_cmd_tty "set -e
        if [ -f \"\$HOME/.cargo/env\" ]; then . \"\$HOME/.cargo/env\"; fi
        cd \"$XTEST_REMOTE_PATH\"
        ./target/release/bowery-console$extra"
}

cmd_stop_ssh() {
    # Close every ControlMaster socket xtest has opened against any host.
    local closed=0
    for sock in "$REPO_ROOT"/.xtest-ssh-*.sock; do
        [[ -S "$sock" ]] || continue
        ssh -o "ControlPath=$sock" -O stop _ 2>/dev/null || true
        rm -f "$sock"
        echo "torn down: $sock"
        closed=1
    done
    [[ $closed -eq 0 ]] && echo "(no active ControlMaster sockets)"
}

# --- Dispatch ----------------------------------------------------------------

if [[ $# -lt 1 ]]; then
    cmd_help
    exit 2
fi

sub="$1"
shift

case "$sub" in
    help|-h|--help) cmd_help ;;
    setup)      cmd_setup ;;
    sync)       cmd_sync ;;
    build)      cmd_build "$@" ;;
    test)       cmd_test "$@" ;;
    clippy)     cmd_clippy ;;
    fmt-check)  cmd_fmt_check ;;
    ci)         cmd_ci ;;
    doctor)     cmd_doctor ;;
    probe)      cmd_probe ;;
    shell)      cmd_shell ;;
    exec)       cmd_exec "$@" ;;
    push-model) cmd_push_model "$@" ;;
    run-agent)    cmd_run_agent "$@" ;;
    run-console)  cmd_run_console "$@" ;;
    stop-ssh)     cmd_stop_ssh ;;
    *)
        echo "error: unknown subcommand '$sub'" >&2
        echo
        cmd_help
        exit 2
        ;;
esac
