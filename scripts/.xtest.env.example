# Sample config for `scripts/xtest`. Copy to `.xtest.env` at the repo
# root (NOT inside scripts/) and adjust to match your VM. The file is
# git-ignored.
#
#     cp scripts/.xtest.env.example .xtest.env
#     ./scripts/xtest setup

# Hostname or IP of the VM. For VirtualBox NAT with port-forward, this
# is typically 127.0.0.1. For bridged networking, use the VM's LAN IP.
XTEST_HOST=127.0.0.1

# SSH user inside the VM.
XTEST_USER=ubuntu

# SSH port. With VirtualBox NAT + port forward (host 2222 -> guest 22),
# use 2222. Default is 22 for bridged networking.
XTEST_PORT=2222

# SSH key. Defaults to ~/.ssh/id_ed25519 if unset.
# XTEST_SSH_KEY=/home/$USER/.ssh/id_ed25519

# Remote workdir. The xtest sync command rsyncs the repo here.
# XTEST_REMOTE_PATH=/home/ubuntu/the_bowery

# Extra cargo flags applied to build/test. Use --release for production
# benchmarks, --offline if you want to fail fast on a missing crate.
# XTEST_CARGO_FLAGS=--release
