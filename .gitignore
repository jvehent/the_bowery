# Rust
/target
**/*.rs.bk
Cargo.lock.bak

# cargo-fuzz artifacts (kept out of the main workspace by exclude)
/fuzz/target
/fuzz/corpus
/fuzz/artifacts
/fuzz/coverage
/fuzz/Cargo.lock

# Editor / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Bowery runtime artifacts (when running locally)
/run/
/var-lib/
/local-bin/        # ad-hoc binary stash for cross-host CLI usage
*.key
!**/testdata/**/*.key

# Windows Zone.Identifier files (WSL)
*:Zone.Identifier

# Coverage / profiling
*.profraw
tarpaulin-report.html

# Local environment overrides
.env
.env.local

# Remote-testing driver state
.xtest.env
.xtest-ssh-*.sock
.claude/
