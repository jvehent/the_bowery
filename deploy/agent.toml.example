# The Bowery agent configuration. Install at /etc/bowery/agent.toml.

[identity]
# Path to the agent's Ed25519 identity key. Generated automatically on first
# start if absent. Must be mode 0600.
path = "/var/lib/bowery/identity.key"

[known_neighbors]
# Persistent TOFU pinning store. New peers are auto-pinned during the
# bootstrap window after first start; outside of it, only operator-signed
# add-neighbor messages can extend the pin set.
path = "/var/lib/bowery/known_neighbors.json"
# Phase-8 hardened default: 2 hours. Lengthen temporarily for staged
# fleet rollouts; do NOT set back to multi-day defaults in production.
# Anyone who can reach the chitchat UDP port during this window can
# get permanently pinned.
bootstrap_window = "2h"
# Hard cap on the pin set. Defends against a chitchat-mesh flood that
# race-publishes synthetic identities during the bootstrap window.
max_pinned_peers = 1024

[mesh]
# UDP socket the chitchat gossip server listens on.
listen_addr = "0.0.0.0:9901"
# Optional: address other peers should use to reach us. Defaults to listen_addr.
# advertise_addr = "10.0.0.5:9901"
# Seed peers (host:port) used to bootstrap into the mesh.
seeds = []
# Cluster identifier; peers with mismatched cluster ids ignore each other.
# cluster_id = "bowery"

[whisper]
# UDP socket the QUIC server binds to.
bind_addr = "0.0.0.0:9902"

[heartbeat]
# Interval between heartbeat sweeps to known neighbors.
interval = "30s"

[baseline]
# SQLite-backed baseline of observed binaries and process lineage. Use the
# literal `:memory:` to keep the baseline in RAM (test/ephemeral agents).
path = "/var/lib/bowery/baseline.db"

[role]
# How often to recompute and publish this node's role vector via the mesh
# KV layer. Other nodes use the role vector to choose similar peers when
# whispering (Phase 5).
publish_interval = "60s"

[llm]
# Pre-filter suspicion above which the LLM analyzer is invoked. The
# analyzer's verdict refines (or escalates) the rule + scorer output.
# Defaults to the deterministic mock backend; for real inference,
# build with `--features llm-llama-cpp` and uncomment [llm.llama_cpp].
invocation_threshold = 0.7
# Maximum pending LLM requests. New requests beyond this are shed to
# prevent the LLM from back-pressuring the event pipeline.
queue_capacity = 32
# Per-request deadline; requests slower than this are abandoned.
request_deadline = "10s"

# Uncomment to switch from the mock to a real Qwen3-0.6B local LLM.
# Requires the binary to be built with `--features llm-llama-cpp`.
#
# [llm.llama_cpp]
# model_path = "/var/lib/bowery/models/qwen3-0.6b-instruct-q4_k_m.gguf"
# n_ctx = 4096
# n_threads = 0       # 0 = llama.cpp default
# n_gpu_layers = 0    # 0 = pure CPU
# max_tokens = 256
# temperature = 0.2   # low temp keeps JSON output stable

[sql]
# Phase-9 native SQL surface (always on). Operators query host
# state via `bowery exec sql --sql '…'`; the agent runs the
# query inside an in-memory SQLite engine with a SELECT-only
# authorizer over the bowery-sql / bowery-tables surface (13
# host-state tables + 4 Bowery-internal views + 7 scalar
# file/hash functions).
#
# expose_cmdline:    when `true`, the `processes` table populates
#                    the `cmdline` column with full argv. argv
#                    routinely contains DB connection strings,
#                    API tokens passed via `--token=…`, and
#                    `$HOME` paths. With fan-out that crosses to
#                    operators authorised on the relay but not on
#                    every peer. OFF by default (SECURITY-AUDIT
#                    F-8); enable only when the operator workflow
#                    needs it and the leak is acceptable.
# expose_cmdline = false
#
# max_concurrent_queries: cap on concurrent operator queries
#                    (each opens a fresh in-memory SQLite,
#                    registering ~17 tables). Past the cap
#                    queries queue at the operator-side QUIC
#                    accept layer until earlier ones drain.
#                    Default 4.
# max_concurrent_queries = 4
#
# max_timeout:       hard ceiling on per-query wall-clock. The
#                    operator's request timeout is clamped to
#                    min(request, max_timeout). Defends against
#                    a stolen operator key hanging the host with
#                    a deliberately long-running query. Default
#                    "30s".
# max_timeout = "30s"

[response]
# Phase-7 response engine. Default-deny: with `engine = "noop"` and
# empty `policy_path`, the agent observes and alerts but takes no
# enforcement action. Switch to `process-kill` or `bpf-lsm` only after
# validating the LLM verdict quality on this fleet.
engine = "noop"
# Path to a TOML file listing `allowed_actions = [...]`. Missing file
# means deny-all (the safe default). Existing entries that don't match
# a known action id are flagged in startup logs.
# policy_path = "/etc/bowery/response-policy.toml"

# Phase-8 H9: signed audit log. Every action attempt produces an
# Ed25519-signed envelope with a hash-chain (per-host monotonic seq +
# prev_sig). Operators verify with `bowery audit verify`. Off by
# default; set to enable.
# audit_log_path = "/var/log/bowery/audit.jsonl"

# Phase-8 H11: extra `comm` strings to add to the BlockExec deny-list
# (defaults already cover sshd, systemd, login, init, etc.). Defends
# against an attacker who calls prctl(PR_SET_NAME) to spoof a critical
# service's comm and trick the LLM into blocking real instances.
# block_exec_deny_list = ["my-critical-app", "site-monitor"]
